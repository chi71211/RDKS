name: 自動化 胎壓 爬蟲

# 設定排程時間
on:
  schedule:
    - cron: '0 */6 * * *' # 每天每 6 小時喚醒一次 (靠進度檔自動接關或跳過)
  workflow_dispatch: # 允許手動隨時執行

# 允許此工作流將檔案提交並寫入回 GitHub 倉庫
permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    # GitHub 預設最長可跑 6 小時。因為我們有進度檔，可以直接給足 360 分鐘讓它跑到滿
    timeout-minutes: 360 

    steps:
      - name: 取得程式碼
        uses: actions/checkout@v4

      - name: 設定 Python 環境
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: 安裝套件
        run: |
          pip install requests pandas openpyxl urllib3

      - name: 執行爬蟲腳本
        run: python 胎壓自動.py

      # 備份防線 1：強制打包成 Artifacts 供手動下載 (新增 scrape_progress.json)
      - name: 上傳爬取結果 (Artifacts 備份)
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: RDKS_Data_Backup
          path: |
            胎壓自動/
            胎壓自動.db
            胎壓自動p.sql
            scrape_progress.json

      # 備份防線 2：自動將最新的進度與資料庫 push 回 GitHub！
      - name: 提交並推送更新進度到 GitHub
        if: always()
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          
          # 🌟 最重要的修改：強制加入 scrape_progress.json 確保不斷線接關
          git add -f 胎壓自動.db || true
          git add -f 胎壓自動.sql || true
          git add -f scrape_progress.json || true
          git add -f 胎壓自動/ || true
          
          # 檢查是否有任何檔案變更，有變更才進行提交
          if git diff --quiet && git diff --staged --quiet; then
            echo "沒有偵測到任何資料更新，跳過提交。"
          else
            git commit -m "🤖 [自動存檔] 爬蟲進度與資料庫更新 [skip ci]"
            git push
          fi
