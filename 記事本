if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="AutoBild 企業級爬蟲")
    parser.add_argument("--test", action="store_true", help="測試模式")
    parser.add_argument("--reset", action="store_true", help="重置所有進度")
    args = parser.parse_args()
   
    if args.reset:
        for f in [Config.DB_FILE, Config.PROGRESS_FILE]:
            if os.path.exists(f): os.remove(f)
        print("✅ 已重置系統")
        sys.exit(0)
   
    scraper = MainScraper(test_mode=args.test)
    asyncio.run(scraper.run())
